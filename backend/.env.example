# Copy to .env and fill in. `.env` is gitignored and must stay that way.
#
# Tests do NOT read DATABASE_URL from here — `make test` overrides it to point
# at the local Postgres from compose.yaml, so a stray test run can never create
# a test database on the production host.

# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-something-random
DJANGO_DEBUG=True
DJANGO_APPEND_SLASH=True

# Ignored while DJANGO_DEBUG=True (settings substitutes localhost).
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=

# Used to build password-reset links.
FRONTEND_URL=http://localhost:3000

# Comma-separated. Defaults to FRONTEND_URL when unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Production: Neon's POOLED endpoint (the one with `-pooler` in the host).
# Settings pins CONN_MAX_AGE=0 and DISABLE_SERVER_SIDE_CURSORS=True for it.
#
# Local development: postgresql://boutique:boutique@localhost:55432/boutique
DATABASE_URL=postgresql://boutique:boutique@localhost:55432/boutique

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
# True runs tasks inline — no broker, no worker. Handy locally; never in prod.
CELERY_TASK_ALWAYS_EAGER=False

# ─── Email (password reset) ──────────────────────────────────────────────────
# Default console backend prints mail to stdout. To use the local Mailpit from
# compose.yaml instead, set the SMTP backend and point it at localhost:1025,
# then read the mail at http://localhost:8025.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Zita Boutique <no-reply@example.com>

# ─── Cloudflare R2 (product images — not wired up yet) ───────────────────────
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_HOST=
